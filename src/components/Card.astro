---
interface Props {
  href: string;
  eyebrow?: string;
  title: string;
  summary?: string;
  meta?: string;
}

const { href, eyebrow, title, summary, meta } = Astro.props;
---

<a
  href={href}
  class="group block p-6 border border-ink-200 rounded-lg bg-ink-50 hover:border-pulse-400 hover:shadow-md transition-all"
>
  {
    eyebrow && (
      <p class="text-xs font-semibold uppercase tracking-widest text-pulse-600 mb-2">
        {eyebrow}
      </p>
    )
  }
  <h3 class="text-xl font-semibold text-heritage-800 group-hover:text-pulse-700 transition-colors">
    {title}
  </h3>
  {summary && <p class="mt-3 text-ink-700 leading-relaxed">{summary}</p>}
  {meta && <p class="mt-4 text-xs text-ink-500">{meta}</p>}
</a>
